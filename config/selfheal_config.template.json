# OpenClaw Self-Heal Configuration v3.0
# Copy this file to selfheal_config.json and customize as needed

{
  "maxAttempts": 3,
  "initialRetryDelaySec": 30,
  "maxRetryDelaySec": 300,
  "circuitBreakThreshold": 5,
  "autoRecoverCircuitBreakHours": 4,
  "notificationCooldownMin": 15,
  "botToken": "YOUR_BOT_TOKEN_HERE",
  "chatId": "YOUR_CHAT_ID_HERE",
  
  "escalateAfterFailures": 3,
  "escalationChatId": "",
  
  "healthResponseTimeWarnMs": 1000,
  "healthResponseTimeCritMs": 5000,
  
  "minFreeDiskMB": 100,
  "checkNodeHealth": true
}

# ============================================================================
# Configuration Options Reference
# ============================================================================

# HEALING ATTEMPTS
# ----------------
# maxAttempts: Number of times to try starting the gateway before trying doctor
# initialRetryDelaySec: Base delay between retry attempts (with exponential backoff)
# maxRetryDelaySec: Maximum delay cap for exponential backoff

# CIRCUIT BREAKER
# ---------------
# circuitBreakThreshold: Consecutive failures before disabling the cron job
# autoRecoverCircuitBreakHours: Hours after which circuit breaker auto-resets

# NOTIFICATIONS
# -------------
# notificationCooldownMin: Minimum minutes between Telegram notifications
# botToken: Telegram bot token (from @BotFather)
# chatId: Your Telegram user/chat ID for notifications

# ESCALATION
# ----------
# escalateAfterFailures: Number of failures before starting escalation
# escalationChatId: Optional different chat ID for critical alerts (empty = same as chatId)

# PREDICTIVE THRESHOLDS
# ---------------------
# healthResponseTimeWarnMs: Response time threshold for warning (milliseconds)
# healthResponseTimeCritMs: Response time threshold for critical alert (milliseconds)

# DEPENDENCY CHECKS
# -----------------
# minFreeDiskMB: Minimum free disk space in MB before triggering warning
# checkNodeHealth: Whether to check Node.js version compatibility

# ============================================================================
# Adaptive Features (Auto-tuned)
# ============================================================================
# The following are automatically adjusted based on healing history:
# - adaptiveRetryDelaySec: Adjusted based on success/failure patterns
# - escalationLevel: Current escalation level (0-3)
# - failurePatterns: Count of each failure type for pattern analysis

# ============================================================================
# Example: High-Availability Setup
# ============================================================================
# {
#   "maxAttempts": 5,
#   "initialRetryDelaySec": 20,
#   "maxRetryDelaySec": 180,
#   "circuitBreakThreshold": 10,
#   "autoRecoverCircuitBreakHours": 2,
